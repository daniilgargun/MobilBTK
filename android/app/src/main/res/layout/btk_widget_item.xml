<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Rounded Background for Highlight -->
    <ImageView
        android:id="@+id/item_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_highlight_background"
        android:visibility="invisible"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Time and Number -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:minWidth="40dp">

            <TextView
                android:id="@+id/lesson_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/lesson_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:30"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Divider -->
        <LinearLayout
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:background="#80FFFFFF" />

        <!-- Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/lesson_subject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Предмет"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/lesson_teacher"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Преподаватель"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/lesson_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Гр."
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginLeft="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/lesson_subgroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(п/г)"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginLeft="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/lesson_room"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Каб."
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginLeft="4dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
